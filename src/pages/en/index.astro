  lang={lang}
>
  <Navbar lang={lang} />
  <main>
    <Hero />
    <ComoCrecer />
    <AdnSocios />
    <NuestrosAliados />
    <NuestrosServicios />
    <Synerlink />
  </main>
  <Footer />
