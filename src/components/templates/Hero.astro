---
const heroBgSrc = "https://www.figma.com/api/mcp/asset/cc63d4f7-3cc4-4e48-ae0b-fb536acfb028";
---

<section id="inicio" class="w-full">
  <!-- Hero image -->
  <div class="w-full h-[320px] md:h-[420px] lg:h-[520px] overflow-hidden">
    <img
      src={heroBgSrc}
      alt="GSS - Convertimos complejidad en sistemas funcionales"
      class="w-full h-full object-cover object-center"
    />
  </div>

  <!-- Hero text -->
  <div class="bg-[#e6e6e6] w-full py-14 px-6 md:px-16 lg:px-24 text-center">
    <h1 class="text-[#16384f] text-3xl md:text-5xl lg:text-[3.5rem] font-bold leading-[1.2] tracking-tight max-w-4xl mx-auto mb-8">
      Convertimos complejidad organizacional en sistemas funcionales
    </h1>
    <p class="text-[#00233d] text-lg md:text-xl lg:text-2xl leading-[1.4] max-w-4xl mx-auto">
      GSS es tu socio estratégico en la construcción de operaciones eficientes.
      Ordenamos procesos, acompañamos transformaciones y habilitamos el crecimiento
      mediante servicios compartidos, consultoría organizacional y tecnología de soporte.
    </p>
  </div>
</section>
