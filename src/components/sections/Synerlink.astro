---
const bgImgSrc = "https://www.figma.com/api/mcp/asset/f9e2f484-5946-483a-ad21-5e133a16e567";
const appIconSrc = "https://www.figma.com/api/mcp/asset/46f7b72b-d748-4abe-b1d0-5499fadf47a8";
const appVectorSrc = "https://www.figma.com/api/mcp/asset/9803da53-d8d3-4c9d-9de5-efc7ae5152d3";
---

<section id="synerlink" class="w-full relative overflow-hidden min-h-[500px]">
  <!-- Background image with blur -->
  <div class="absolute inset-0">
    <img
      src={bgImgSrc}
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover"
      style="filter: blur(9px); transform: scale(1.05) rotate(180deg);"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[rgba(8,1,91,0.5)] to-[rgba(255,0,4,0.2)] mix-blend-soft-light"></div>
    <div class="absolute inset-0 bg-[rgba(0,0,0,0.3)]"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-[1400px] mx-auto px-6 md:px-12 lg:px-20 py-16 flex flex-col lg:flex-row items-center justify-between gap-12">

    <!-- Left: text card -->
    <div class="lg:w-[500px] shrink-0 bg-[#3c70bb] bg-opacity-95 rounded-lg p-10">
      <p class="text-[#f3f3f3] text-lg font-semibold leading-[1.2] tracking-tight mb-4">
        AHORRA TIEMPO Y ENERGÍA CON
      </p>
      <p class="text-[#f3f3f3] text-4xl md:text-[2.8rem] font-bold leading-[1.2] tracking-tight">
        SYNERLINK, nuestro novedoso desarrollo de software para hacerte la vida más sencilla
      </p>
    </div>

    <!-- Right: app icon -->
    <div class="flex flex-col items-center gap-6">
      <p class="text-white text-2xl md:text-3xl font-medium leading-[1.2] text-center max-w-[340px]">
        GESTIONAMOS TUS SOLICITUDES VÍA:
      </p>
      <div class="w-[240px] h-[240px] relative overflow-hidden rounded-2xl">
        <img src={appIconSrc} alt="Synerlink App" class="absolute inset-0 w-full h-full object-cover" />
        <img src={appVectorSrc} alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-contain" />
      </div>
    </div>

  </div>
</section>
